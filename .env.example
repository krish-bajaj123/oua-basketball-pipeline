# Postgres
PG_DB=usports
PG_USER=krish
PG_PASSWORD=krish123

# Real AWS S3 credentials (REQUIRED — no defaults)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
